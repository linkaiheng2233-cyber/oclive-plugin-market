VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_ADMIN_EMAILS=

# 可选：模拟 GitHub Pages 子路径（默认 /）。本地 dev 见 vite.config 固定 5173 + strictPort。
# VITE_BASE=/oclive-plugin-market/
