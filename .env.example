# 复制为 .env.local 后填写（勿提交 .env.local）
# GitHub Pages：在仓库 Settings → Secrets and variables → Actions 中配置同名变量，CI 会注入构建。

# 必填：Supabase（Project Settings → API）
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# 可选：管理员邮箱（逗号分隔），与 profiles.is_admin 一起决定管理入口
VITE_ADMIN_EMAILS=

# GitHub Pages 子路径由 CI 自动设置，本地开发勿填或填 /
# VITE_BASE=/

# 可选：版本页 GitHub Releases（默认与上游仓库一致）
# VITE_RELEASE_OWNER=linkaiheng2233-cyber
# VITE_RELEASE_REPO_LAUNCHER=oclive-launcher
# VITE_RELEASE_REPO_EDITOR=oclive-pack-editor
# VITE_RELEASE_REPO_RUNTIME=oclivenewnew
