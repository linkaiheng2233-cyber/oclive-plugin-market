VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_ADMIN_EMAILS=

# 可选：模拟 GitHub Pages 子路径（默认 /）。本地 dev 见 vite.config 固定 5173 + strictPort。
# VITE_BASE=/oclive-plugin-market/
# Supabase → Authentication → URL Configuration 的 Redirect URLs 需包含：
# http://localhost:5173/** 以及（若设置了 VITE_BASE）对应子路径，例如 http://localhost:5173/oclive-plugin-market/**

# 可选：模块组合页「打开编写器」按钮的目标（默认已指向 GitHub Pages 示例站）
# VITE_PACK_EDITOR_URL=https://你的用户名.github.io/oclive-pack-editor/
